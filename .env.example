# Copy to .env for local development
# Use port 5433 — Docker maps host 5433 → container 5432 (avoids Windows Postgres on 5432)
DATABASE_URI=postgresql://atc:atc_secret@localhost:5433/atc_website
PAYLOAD_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3002

# Coolify / production (set in Coolify UI — never commit real secrets)
# DATABASE_URI=postgresql://atc:YOUR_PASSWORD@atc-postgres:5432/atc_website
# NEXT_PUBLIC_SERVER_URL=http://your-app.sslip.io
# AUTO_SEED=true
# SEED_ADMIN_EMAIL=admin@africantradechamber.org
# SEED_ADMIN_PASSWORD=choose-a-strong-password

# Optional: recipient for country office "Request Our Services" form (mailto)
# NEXT_PUBLIC_SERVICE_REQUEST_EMAIL=info@africantradechamber.org

# First admin user (created by seed when no users exist)
SEED_ADMIN_EMAIL=admin@africantradechamber.org
SEED_ADMIN_PASSWORD=ChangeMe-Atc-Dev-2026!
